# Auto detect text files and ensure LF line endings
* text=auto eol=lf

# Go source
*.go text eol=lf

# Shell scripts
*.sh text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf

# Dockerfile
Dockerfile text eol=lf

# Ensure binaries are not treated as text
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.db binary
